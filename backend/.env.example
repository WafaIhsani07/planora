PORT=5000

# Prisma (PostgreSQL)
# - Gunakan DATABASE_URL untuk koneksi normal (atau URL PgBouncer jika memakai pooling)
# - Gunakan DIRECT_URL untuk koneksi direct/non-pooled (disarankan untuk migrate jika pooler terbatas)
#
# Contoh (ganti dengan nilai kamu sendiri):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"